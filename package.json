{
  "name": "ai-kamera-cz",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "config": "expo config --type public",
    "doctor": "npx expo-doctor",
    "ios:dev": "expo start --dev-client",
    "eas:configure": "npx eas-cli build:configure",
    "eas:ios:dev": "npx eas-cli build --platform ios --profile development",
    "native:build": "cd native/AIKameraNative && ../../scripts/xtool-native.sh dev build",
    "native:package": "./scripts/package_native_tipa.sh",
    "native:stage": "./scripts/stage_native_build.sh",
    "native:install": "./scripts/install_native_on_phone.sh"
  },
  "dependencies": {
    "expo": "~55.0.5",
    "expo-dev-client": "~55.0.11",
    "expo-file-system": "~55.0.10",
    "expo-localization": "~55.0.8",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets-core": "^1.6.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
